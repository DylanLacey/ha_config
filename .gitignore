# git-ha-ppens: Auto-generated .gitignore for Home Assistant
# Sensitive files
secrets.yaml
.storage/
.cloud/
tls/
.ssh/

# Database and logs
*.db
*.db-shm
*.db-wal
*.log
home-assistant_v2.db
home-assistant.log*
zigbee.db
OZW_Log.txt

# System files
.HA_VERSION
known_devices.yaml

# Python cache
__pycache__/
*.pyc
*.pyo

# Other
.git/
deps/
tts/
.venv/
custom_components/
www/snapshots/

# Zigbee2MQTT
zigbee2mqtt/state.json
zigbee2mqtt/coordinator_backup.json

# Sensitive/runtime files
.jwt_secret
SERVICE_ACCOUNT.json
.cache/
.claude/
ip_bans.yaml
.ha_run.lock
.exports
.timeline
.vacuum

# Editor swap files
*.swp
*.swo

# Claude Code
CLAUDE.md
